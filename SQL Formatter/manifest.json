{
  "manifest_version": 3,
  "name": "SQL Formatter",
  "version": "3.2",
  "description": "SQL Formatter",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["injector.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["helper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
