{
  "manifest_version": 3,
  "name": "MongoDB Formatter",
  "version": "6.3",
  "description": "MongoDB Formatter",
  "permissions": [
    "storage",
    "scripting",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  }
}